{
  "hooks": {
    "SessionStart": [
      { "hooks": [ { "type": "command", "command": "uvx --from tessera-mcp tessera-mcp hook session-start" } ] }
    ],
    "UserPromptSubmit": [
      { "hooks": [ { "type": "command", "command": "uvx --from tessera-mcp tessera-mcp hook user-prompt-submit" } ] }
    ],
    "SessionEnd": [
      { "hooks": [ { "type": "command", "command": "uvx --from tessera-mcp tessera-mcp hook session-end" } ] }
    ]
  }
}
